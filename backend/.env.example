# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/chaos_messenger
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Redis ---
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=change-me-to-a-secret-at-least-32-chars-long!!
JWT_EXPIRATION=86400000

# --- CORS ---
CHAOS_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://192.168.*.*:*
CHAOS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Push Notifications (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Attachments ---
CHAOS_ATTACHMENTS_STORAGE_PATH=./attachments

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=dev
