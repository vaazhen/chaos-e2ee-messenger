# ── Chaos Messenger — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required:
#   POSTGRES_PASSWORD, REDIS_PASSWORD, JWT_SECRET, DOMAIN, CORS_ORIGINS
#
# Optional:
#   GRAFANA_ADMIN_PASSWORD (default: generated)
#   CHAOS_DEMO_ENABLED (default: false)

# ── Database ────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_at_least_16_chars
REDIS_PASSWORD=CHANGE_ME_another_long_random_secret
JWT_SECRET=CHANGE_ME_32_char_minimum_!!_generate_with_openssl

# ── Domain (without https://) ───────────────────────────────
DOMAIN=your-domain.com
CORS_ORIGINS=https://your-domain.com

# ── Admin Credentials ───────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_also_admin

# ── Optional: Demo Mode ────────────────────────────────────
# Set to "true" to enable /api/demo/seed endpoint
CHAOS_DEMO_ENABLED=false

# ── Optional: Push Notifications (VAPID) ───────────────────
# Generate: openssl ecparam -genkey -name prime256v1 -out vapid-private.pem
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
